# The Kraken v2 — Example environment configuration
#
# Copy to .env and fill in real values for local development.
# .env files are gitignored. Never commit real credentials.
# In production, all of these are injected from the K8s Secret + ConfigMap
# (see charts/thekraken/templates/secret.yaml and configmap.yaml).

# ---------------------------------------------------------------------------
# Slack
# ---------------------------------------------------------------------------

# Slack bot OAuth token (xoxb-...). Required.
SLACK_BOT_TOKEN=xoxb-REPLACE-ME

# Slack transport mode: "http" (production, requires SIGNING_SECRET) or
# "socket" (local dev, requires APP_TOKEN). Default: http.
SLACK_MODE=socket

# Required if SLACK_MODE=http. Slack signing secret for Events API.
# SLACK_SIGNING_SECRET=REPLACE-ME

# Required if SLACK_MODE=socket. Slack app-level token (xapp-...).
SLACK_APP_TOKEN=xapp-REPLACE-ME

# ---------------------------------------------------------------------------
# OIDC (Keycloak)
# ---------------------------------------------------------------------------

# Keycloak realm URL (e.g., https://keycloak.example.com/realms/tentacular). Required.
OIDC_ISSUER=https://keycloak.example.com/realms/tentacular

# OIDC client ID. Required.
# Note: see followup F-OIDC-CLIENT-TYPE in scratch/kraken-v2-followups.md —
# Phase 2 must clarify whether this client is public (device flow) or
# confidential (and thus needs OIDC_CLIENT_SECRET).
OIDC_CLIENT_ID=thekraken

# OIDC client secret (only needed for confidential clients; omit for public clients).
# OIDC_CLIENT_SECRET=REPLACE-ME

# ---------------------------------------------------------------------------
# Token Encryption (Phase 2+)
# ---------------------------------------------------------------------------

# AES-256-GCM key used to encrypt OIDC tokens at rest in SQLite.
# REQUIRED. Generate with: openssl rand -hex 32
# Must be 32 bytes (64 hex chars) or base64-encoded 32 bytes (44 chars).
KRAKEN_TOKEN_ENCRYPTION_KEY=REPLACE-ME-openssl-rand-hex-32

# ---------------------------------------------------------------------------
# Tentacular MCP
# ---------------------------------------------------------------------------

# URL of the in-cluster Tentacular MCP server. Required.
TENTACULAR_MCP_URL=https://tentacular-mcp.example.com

# MCP server port (default: 8080).
# MCP_PORT=8080

# ---------------------------------------------------------------------------
# LLM Providers
# ---------------------------------------------------------------------------

# Default provider: anthropic | openai | google. Default: anthropic.
LLM_DEFAULT_PROVIDER=anthropic

# Default model ID. Must be in the allowed list. Default: claude-sonnet-4-6.
LLM_DEFAULT_MODEL=claude-sonnet-4-6

# Comma-separated list of allowed providers.
LLM_ALLOWED_PROVIDERS=anthropic,openai,google

# Per-provider allowed models. Format: comma-separated provider entries,
# each provider:model1|model2|model3 (pipe between models within a provider).
LLM_ALLOWED_MODELS=anthropic:claude-sonnet-4-6|claude-opus-4-6,openai:gpt-5.3-chat-latest,google:gemini-3-pro-preview

# Comma-separated list of disallowed model IDs (always rejected).
LLM_DISALLOWED_MODELS=gpt-4o,o3,o4-mini,gpt-5-nano,gpt-5-mini,gemini-2.5-pro

# At least one provider's API key must be set in the production Helm Secret
# (these are not loaded by config.ts directly; the LLM client picks them up).
# ANTHROPIC_API_KEY=sk-ant-REPLACE-ME
# OPENAI_API_KEY=sk-REPLACE-ME
# GEMINI_API_KEY=REPLACE-ME

# ---------------------------------------------------------------------------
# Git-Backed State (MANDATORY — Kraken refuses to start if unset)
# ---------------------------------------------------------------------------

# HTTPS URL of the git-state repository. Required.
GIT_STATE_REPO_URL=https://github.com/randybias/mirantis-tentacle-workflows.git

# Branch to clone/pull. Default: main.
# GIT_STATE_BRANCH=main

# Local clone directory inside the container/PVC. Default: /app/data/git-state.
# GIT_STATE_DIR=/app/data/git-state

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------

# HTTP server port for /healthz (and Slack Events API in HTTP mode).
# Default: 3000.
# PORT=3000
