    <mxCell id="s8-check" value="8. Check all tokens&lt;br&gt;expires_at - now &lt; 10 min?" style="rhombus;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;html=1;" vertex="1" parent="1">
