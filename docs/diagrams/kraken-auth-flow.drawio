      <mxGeometry x="920" y="80" width="200" height="1020" as="geometry"/>
    </mxCell>

    <!-- Background Refresh -->
    <mxCell id="lane-refresh" value="Background Refresh Loop" style="swimlane;startSize=40;horizontal=0;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=13;" vertex="1" parent="1">
      <mxGeometry x="1140" y="80" width="200" height="1020" as="geometry"/>
    </mxCell>

    <!-- ===== STEP 1: User @mentions, no token ===== -->
    <mxCell id="s1" value="1. User @mentions Kraken" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;html=1;" vertex="1" parent="1">
      <mxGeometry x="60" y="160" width="160" height="50" as="geometry"/>
    </mxCell>

    <!-- ===== STEP 2: Kraken checks SQLite, no token ===== -->
    <mxCell id="s2" value="2. getValidTokenForUser&lt;br&gt;(no token in SQLite)" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;html=1;" vertex="1" parent="1">
      <mxGeometry x="500" y="250" width="160" height="60" as="geometry"/>
    </mxCell>

    <!-- ===== STEP 3: initiateDeviceAuth ===== -->
    <mxCell id="s3-call" value="3. initiateDeviceAuth()" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;html=1;" vertex="1" parent="1">
      <mxGeometry x="500" y="360" width="160" height="50" as="geometry"/>
    </mxCell>

    <!-- ===== STEP 3b: Keycloak returns device code ===== -->
    <mxCell id="s3b-resp" value="returns: device_code&lt;br&gt;user_code&lt;br&gt;verification_uri" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;html=1;" vertex="1" parent="1">
      <mxGeometry x="720" y="360" width="160" height="70" as="geometry"/>
    </mxCell>

    <!-- ===== STEP 4: Post ephemeral Slack message ===== -->
    <mxCell id="s4-ephemeral" value="4. Post ephemeral Slack message&lt;br&gt;with URL + user_code" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;html=1;" vertex="1" parent="1">
      <mxGeometry x="500" y="480" width="160" height="60" as="geometry"/>
    </mxCell>

    <!-- ===== STEP 4b: Slack shows message to user ===== -->
    <mxCell id="s4b-slack" value="ephemeral message&lt;br&gt;shown to user only" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;html=1;" vertex="1" parent="1">
      <mxGeometry x="280" y="490" width="160" height="55" as="geometry"/>
    </mxCell>

    <!-- ===== STEP 5: User opens URL in browser ===== -->
    <mxCell id="s5-browser" value="5. User opens URL&lt;br&gt;enters user_code&lt;br&gt;logs in (Google SSO)" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;html=1;" vertex="1" parent="1">
      <mxGeometry x="60" y="580" width="160" height="70" as="geometry"/>
    </mxCell>

    <!-- ===== STEP 5b: Keycloak processes login ===== -->
