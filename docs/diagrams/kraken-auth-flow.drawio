    <mxCell id="s8-refresh" value="refresh_token flow&lt;br&gt;Keycloak returns new tokens" style="rounded=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;html=1;" vertex="1" parent="1">
